---
import type { FeaturedProject } from '../../data/site';

interface Props {
  project: FeaturedProject;
  imageSrc?: string;
}

const { project, imageSrc: imageOverride } = Astro.props;

const techCategories = project.techCategories;
const imageSrc = imageOverride ?? (project.image ? (project.image.startsWith('/') ? project.image : `/${project.image}`) : undefined);
---

<article class="panel-card group space-y-6">
  <header>
    <h3 class="text-2xl font-semibold text-slate-lightest">
      {project.title}
    </h3>
    {project.period && <p class="mt-1 font-mono text-sm text-accent">{project.period}</p>}
  </header>

  {imageSrc && (
    <div class="w-full max-w-3xl overflow-hidden rounded-xl border border-navy-lighter/80 bg-navy-light/20">
      <img
        src={imageSrc}
        alt={project.imageAlt ?? ''}
        class="w-full h-56 object-cover"
        loading="lazy"
        decoding="async"
      />
    </div>
  )}

  <div class="space-y-4">
    <p class="body-copy">{project.summary}</p>

    {project.solution && (
      <div>
        <dt class="text-xs uppercase tracking-wider text-accent">Solution</dt>
        <dd class="mt-1.5 text-slate">{project.solution}</dd>
      </div>
    )}
    {project.impact && (
      <div>
        <dt class="text-xs uppercase tracking-wider text-accent">Impact</dt>
        <dd class="mt-1.5 text-slate">{project.impact}</dd>
      </div>
    )}
  </div>

  <div>
    <dt class="mb-3 text-xs uppercase tracking-wider text-accent">Technologies / Tools</dt>
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
      {techCategories.map((techCat) => (
        <div>
          <h4 class="mb-2 text-xs uppercase tracking-wider text-slate-lightest">
            {techCat.category}
          </h4>
          <ul class="space-y-1">
            {techCat.items.map((item) => (
              <li class="text-sm text-slate-light">{item}</li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</article>
